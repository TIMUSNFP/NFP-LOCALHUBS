PORT=4000

# Secret used to sign admin JWTs. Replace with your own random string in production.
JWT_SECRET=5406b585c04b319bcfc72f39eb6dc19a82e9f576154c9e1338eb2ac63e854cc

# Admin login credentials.
# Demo password for the hash below is: admin123
ADMIN_EMAIL=admin@networkfp.com
ADMIN_PASSWORD_HASH=$2a$10$LJOV3j0TzGW8vxzPaDAly.NJL7.SkhnyQtxZjKqOLDsCmOgoRLG26

# Comma-separated list of allowed CORS origins, e.g.:
# ALLOWED_ORIGINS=https://hub-leader.example.com,https://participant.example.com,https://admin.example.com
# Leave empty during local development to reflect any origin (see server.js).
ALLOWED_ORIGINS=

# Google Sheets sync — paste your Google Apps Script Web App URL here.
# See admin setup instructions for how to create and deploy the Apps Script.
SHEETS_WEBHOOK_URL=

# SMTP email notifications (nodemailer).
# Google Workspace : SMTP_HOST=smtp.gmail.com     SMTP_PORT=465
# Microsoft 365    : SMTP_HOST=smtp.office365.com SMTP_PORT=587
# Zoho Mail        : SMTP_HOST=smtp.zoho.com      SMTP_PORT=465
# SMTP_USER is the full mailbox address; SMTP_PASS is an App Password (not the login password).
# FROM_EMAIL must match SMTP_USER or a permitted send-as alias.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=NFP Circles <noreply@networkfp.com>
